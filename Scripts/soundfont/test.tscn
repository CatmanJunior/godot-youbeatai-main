[sub_resource type="GDScript" id="GDScript_dn6mc"]
resource_name = "load"
script/source = "extends Control

@export var bankData : EffectProfile:
	set(v):
		bankData.Apply(AudioServer.get_bus_index(\"Purple\"))	

func _ready():
	bankData.Apply(AudioServer.get_bus_index(\"Purple\"))


	var combine_threshold = 0
	# expected: {(3,1),(1,4),(1,5)....
	var array = [1,1,1,4,5,12,5,5,7,6,8,32,34]
	var result: Array[SequenceNote] = []
	for index in range(len(array)):
		var current = array[index]
		var last: SequenceNote = result.back()
		if last == null or abs(last.note - current) > combine_threshold:
			last = SequenceNote.new()
			last.note = current
			last.beat = index
			result.append(last)
		else:
			last.duration += 1
		
		
	
	for index in range(len(result)):
		print(\"note: %d, duration: %d\" % [result[index].note, result[index].duration])
"

