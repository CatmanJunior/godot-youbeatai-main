[configuration]
entry_symbol = "library_init"
compatibility_minimum = 4.4

[icons]
SoundFont = "icons/piano.svg"
SoundFontPlayer = "icons/piano.svg"

[libraries]
android.debug.x86_64 = "res://addons/soundfont/lib/libgdexample.android.template_debug.x86_64.so"
android.release.x86_64 = "res://addons/soundfont/lib/libgdexample.android.template_release.x86_64.so"
android.debug.arm64 = "res://addons/soundfont/lib/libgdexample.android.template_debug.arm64.so"
android.release.arm64 = "res://addons/soundfont/lib/libgdexample.android.template_release.arm64.so"
android.debug.rv64 = "res://addons/soundfont/lib/libgdexample.android.template_debug.rv64.so"
android.release.rv64 = "res://addons/soundfont/lib/libgdexample.android.template_release.rv64.so"

macos.debug = "res://addons/soundfont/lib/libgdexample.macos.template_debug.framework"
macos.release = "res://addons/soundfont/lib/libgdexample.macos.template_release.framework"
windows.debug.x86_32 = "res://addons/soundfont/lib/libgdexample.windows.template_debug.x86_32.dll"
windows.release.x86_32 = "res://addons/soundfont/lib/libgdexample.windows.template_release.x86_32.dll"
windows.debug.x86_64 = "res://addons/soundfont/lib/libgdexample.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://addons/soundfont/lib/libgdexample.windows.template_release.x86_64.dll"
linux.debug.x86_64 = "res://addons/soundfont/lib/libgdexample.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://addons/soundfont/lib/libgdexample.linux.template_release.x86_64.so"
linux.debug.arm64 = "res://addons/soundfont/lib/libgdexample.linux.template_debug.arm64.so"
linux.release.arm64 = "res://addons/soundfont/lib/libgdexample.linux.template_release.arm64.so"
linux.debug.rv64 = "res://addons/soundfont/lib/libgdexample.linux.template_debug.rv64.so"
linux.release.rv64 = "res://addons/soundfont/lib/libgdexample.linux.template_release.rv64.so"